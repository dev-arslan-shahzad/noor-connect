# Default: auto-detect text files, normalize to LF in the repo.
* text=auto eol=lf

# Source code — always LF (works on every platform).
*.py text eol=lf
*.ts text eol=lf
*.tsx text eol=lf
*.js text eol=lf
*.jsx text eol=lf
*.mjs text eol=lf
*.cjs text eol=lf
*.json text eol=lf
*.jsonc text eol=lf
*.html text eol=lf
*.css text eol=lf
*.scss text eol=lf
*.md text eol=lf
*.yml text eol=lf
*.yaml text eol=lf
*.toml text eol=lf
*.sh text eol=lf
*.env text eol=lf
*.env.* text eol=lf
.gitignore text eol=lf
.gitattributes text eol=lf

# Windows-only scripts must keep CRLF or cmd.exe / PowerShell may misbehave.
*.bat text eol=crlf
*.cmd text eol=crlf
*.ps1 text eol=crlf

# Binary assets — never touch line endings, never diff as text.
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.webp binary
*.ico binary
*.svg binary
*.pdf binary
*.zip binary
*.gz binary
*.woff binary
*.woff2 binary
*.ttf binary
*.otf binary
*.eot binary

# Auto-generated — don't show in PR diffs by default.
frontend/src/routeTree.gen.ts linguist-generated=true
package-lock.json linguist-generated=true

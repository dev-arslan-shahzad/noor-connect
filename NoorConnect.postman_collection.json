{
  "info": {
    "name": "NoorConnect API",
    "description": "Complete API collection for NoorConnect — Quran learning & verified tutor platform.\n\nRecommended run order:\n1. Auth > Register student\n2. Auth > Register teacher\n3. Teachers > Apply (form-data, requires teacher login — re-login with teacher creds first)\n4. Manually approve teacher in Django admin (http://127.0.0.1:8000/admin/)\n5. Auth > Login (as student)\n6. Teachers > List teachers (captures teacherId)\n7. Bookings > Create booking (captures bookingId + sessionId)\n8. Sessions > End session (marks booking completed)\n9. Reviews > Create review\n\nTokens auto-save to collection variables via Tests scripts.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json",
    "_postman_id": "noorconnect-api-collection"
  },
  "auth": {
    "type": "bearer",
    "bearer": [{ "key": "token", "value": "{{accessToken}}", "type": "string" }]
  },
  "variable": [
    { "key": "baseUrl", "value": "http://127.0.0.1:8000/api", "type": "string" },
    { "key": "accessToken", "value": "", "type": "string" },
    { "key": "refreshToken", "value": "", "type": "string" },
    { "key": "teacherId", "value": "", "type": "string" },
    { "key": "bookingId", "value": "", "type": "string" },
    { "key": "sessionId", "value": "", "type": "string" }
  ],
  "item": [
    {
      "name": "Auth",
      "item": [
        {
          "name": "Register student",
          "request": {
            "auth": { "type": "noauth" },
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": {
              "raw": "{{baseUrl}}/auth/register/",
              "host": ["{{baseUrl}}"],
              "path": ["auth", "register", ""]
            },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"role\": \"student\",\n  \"full_name\": \"Ali Hassan\",\n  \"email\": \"student1@test.com\",\n  \"password\": \"noor1234\",\n  \"phone\": \"03001234567\",\n  \"city\": \"Lahore\",\n  \"is_learning_for_child\": false,\n  \"child_name\": \"\",\n  \"child_age\": null\n}"
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status 201', () => pm.response.to.have.status(201));",
                  "const json = pm.response.json();",
                  "if (json.data && json.data.access) {",
                  "  pm.collectionVariables.set('accessToken', json.data.access);",
                  "  pm.collectionVariables.set('refreshToken', json.data.refresh);",
                  "  console.log('Saved student tokens');",
                  "}"
                ]
              }
            }
          ]
        },
        {
          "name": "Register teacher",
          "request": {
            "auth": { "type": "noauth" },
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": {
              "raw": "{{baseUrl}}/auth/register/",
              "host": ["{{baseUrl}}"],
              "path": ["auth", "register", ""]
            },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"role\": \"teacher\",\n  \"full_name\": \"Ustadh Ahmed Khan\",\n  \"email\": \"teacher1@test.com\",\n  \"password\": \"noor1234\",\n  \"phone\": \"03007654321\",\n  \"city\": \"Lahore\"\n}"
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status 201', () => pm.response.to.have.status(201));",
                  "const json = pm.response.json();",
                  "if (json.data && json.data.access) {",
                  "  pm.collectionVariables.set('accessToken', json.data.access);",
                  "  pm.collectionVariables.set('refreshToken', json.data.refresh);",
                  "  console.log('Saved teacher tokens — accessToken now belongs to teacher');",
                  "}"
                ]
              }
            }
          ]
        },
        {
          "name": "Login (student)",
          "request": {
            "auth": { "type": "noauth" },
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": {
              "raw": "{{baseUrl}}/auth/login/",
              "host": ["{{baseUrl}}"],
              "path": ["auth", "login", ""]
            },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"student1@test.com\",\n  \"password\": \"noor1234\"\n}"
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status 200', () => pm.response.to.have.status(200));",
                  "const json = pm.response.json();",
                  "if (json.data && json.data.access) {",
                  "  pm.collectionVariables.set('accessToken', json.data.access);",
                  "  pm.collectionVariables.set('refreshToken', json.data.refresh);",
                  "}"
                ]
              }
            }
          ]
        },
        {
          "name": "Login (teacher)",
          "request": {
            "auth": { "type": "noauth" },
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": {
              "raw": "{{baseUrl}}/auth/login/",
              "host": ["{{baseUrl}}"],
              "path": ["auth", "login", ""]
            },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"teacher1@test.com\",\n  \"password\": \"noor1234\"\n}"
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status 200', () => pm.response.to.have.status(200));",
                  "const json = pm.response.json();",
                  "if (json.data && json.data.access) {",
                  "  pm.collectionVariables.set('accessToken', json.data.access);",
                  "  pm.collectionVariables.set('refreshToken', json.data.refresh);",
                  "}"
                ]
              }
            }
          ]
        },
        {
          "name": "Get current user (me)",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/auth/me/",
              "host": ["{{baseUrl}}"],
              "path": ["auth", "me", ""]
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": ["pm.test('Status 200', () => pm.response.to.have.status(200));"]
              }
            }
          ]
        },
        {
          "name": "Update profile (me)",
          "request": {
            "method": "PATCH",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": {
              "raw": "{{baseUrl}}/auth/me/",
              "host": ["{{baseUrl}}"],
              "path": ["auth", "me", ""]
            },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"phone\": \"03009999999\",\n  \"city\": \"Karachi\"\n}"
            }
          }
        },
        {
          "name": "Refresh access token",
          "request": {
            "auth": { "type": "noauth" },
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": {
              "raw": "{{baseUrl}}/auth/token/refresh/",
              "host": ["{{baseUrl}}"],
              "path": ["auth", "token", "refresh", ""]
            },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"refresh\": \"{{refreshToken}}\"\n}"
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status 200', () => pm.response.to.have.status(200));",
                  "const json = pm.response.json();",
                  "if (json.access) pm.collectionVariables.set('accessToken', json.access);",
                  "if (json.refresh) pm.collectionVariables.set('refreshToken', json.refresh);"
                ]
              }
            }
          ]
        },
        {
          "name": "Logout",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": {
              "raw": "{{baseUrl}}/auth/logout/",
              "host": ["{{baseUrl}}"],
              "path": ["auth", "logout", ""]
            },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"refresh\": \"{{refreshToken}}\"\n}"
            }
          }
        }
      ]
    },
    {
      "name": "Teachers",
      "item": [
        {
          "name": "List teachers (public, with filters)",
          "request": {
            "auth": { "type": "noauth" },
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/teachers/?ordering=highest_rated&max_price=15000",
              "host": ["{{baseUrl}}"],
              "path": ["teachers", ""],
              "query": [
                { "key": "subject", "value": "Tajweed", "disabled": true },
                { "key": "gender", "value": "female", "disabled": true },
                { "key": "mode", "value": "online", "description": "online | inperson | both", "disabled": true },
                { "key": "city", "value": "Lahore", "disabled": true },
                { "key": "min_price", "value": "500", "disabled": true },
                { "key": "max_price", "value": "15000" },
                { "key": "rating", "value": "4", "disabled": true },
                { "key": "search", "value": "Ahmed", "disabled": true },
                { "key": "ordering", "value": "highest_rated", "description": "highest_rated | lowest_price | highest_price | most_reviews | newest" },
                { "key": "featured", "value": "true", "disabled": true }
              ]
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status 200', () => pm.response.to.have.status(200));",
                  "const results = pm.response.json().data.results;",
                  "if (results && results.length) {",
                  "  pm.collectionVariables.set('teacherId', results[0].id);",
                  "  console.log('Captured teacherId =', results[0].id);",
                  "}"
                ]
              }
            }
          ]
        },
        {
          "name": "Teacher detail (public)",
          "request": {
            "auth": { "type": "noauth" },
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/teachers/{{teacherId}}/",
              "host": ["{{baseUrl}}"],
              "path": ["teachers", "{{teacherId}}", ""]
            }
          }
        },
        {
          "name": "Apply as teacher (form-data, auth=teacher)",
          "request": {
            "method": "POST",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/teachers/apply/",
              "host": ["{{baseUrl}}"],
              "path": ["teachers", "apply", ""]
            },
            "body": {
              "mode": "formdata",
              "formdata": [
                { "key": "bio", "value": "Hafiz with 10 years of teaching experience. Specializes in Tajweed and Hifz for kids and adults.", "type": "text" },
                { "key": "gender", "value": "male", "type": "text" },
                { "key": "teaching_mode", "value": "both", "type": "text", "description": "online | inperson | both" },
                { "key": "years_experience", "value": "10", "type": "text" },
                { "key": "hourly_rate", "value": "1200", "type": "text" },
                { "key": "city", "value": "Lahore", "type": "text" },
                { "key": "latitude", "value": "31.5497", "type": "text" },
                { "key": "longitude", "value": "74.3436", "type": "text" },
                { "key": "subjects", "value": "Tajweed", "type": "text", "description": "Send subjects multiple times to build an array" },
                { "key": "subjects", "value": "Hifz", "type": "text" },
                { "key": "subjects", "value": "Nazra", "type": "text" },
                { "key": "languages", "value": "Urdu", "type": "text" },
                { "key": "languages", "value": "English", "type": "text" },
                { "key": "languages", "value": "Arabic", "type": "text" },
                { "key": "certificate", "type": "file", "src": [], "description": "Attach a PDF or image" },
                { "key": "cnic", "type": "file", "src": [], "description": "Attach an image" }
              ]
            },
            "description": "Login as teacher first (use 'Login (teacher)' or run 'Register teacher'). Status starts as 'pending' — approve via Django admin to make it 'verified'."
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status 201', () => pm.response.to.have.status(201));",
                  "const tp = pm.response.json().data && pm.response.json().data.teacher_profile;",
                  "if (tp && tp.id) pm.collectionVariables.set('teacherId', tp.id);"
                ]
              }
            }
          ]
        },
        {
          "name": "Nearby teachers (public)",
          "request": {
            "auth": { "type": "noauth" },
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/teachers/nearby/?lat=31.5497&lng=74.3436&radius=25",
              "host": ["{{baseUrl}}"],
              "path": ["teachers", "nearby", ""],
              "query": [
                { "key": "lat", "value": "31.5497" },
                { "key": "lng", "value": "74.3436" },
                { "key": "radius", "value": "25", "description": "km, default 10" },
                { "key": "subject", "value": "Tajweed", "disabled": true },
                { "key": "gender", "value": "female", "disabled": true },
                { "key": "city", "value": "Lahore", "disabled": true }
              ]
            }
          }
        },
        {
          "name": "Update own teacher profile",
          "request": {
            "method": "PATCH",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": {
              "raw": "{{baseUrl}}/teachers/{{teacherId}}/update/",
              "host": ["{{baseUrl}}"],
              "path": ["teachers", "{{teacherId}}", "update", ""]
            },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"bio\": \"Updated bio. Patient, structured, and warm.\",\n  \"hourly_rate\": \"1500\",\n  \"teaching_mode\": \"online\"\n}"
            },
            "description": "Must be logged in as the same teacher user."
          }
        }
      ]
    },
    {
      "name": "Bookings",
      "item": [
        {
          "name": "Create booking (auth=student)",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": {
              "raw": "{{baseUrl}}/bookings/create/",
              "host": ["{{baseUrl}}"],
              "path": ["bookings", "create", ""]
            },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"teacher_id\": {{teacherId}},\n  \"subject\": \"Tajweed\",\n  \"session_type\": \"trial\",\n  \"date\": \"2026-05-25\",\n  \"start_time\": \"17:00:00\",\n  \"end_time\": \"17:30:00\"\n}"
            },
            "description": "Teacher must be verified. Time format HH:MM:SS (24-hour). session_type = trial (30 min, free) or regular (paid)."
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status 201', () => pm.response.to.have.status(201));",
                  "const b = pm.response.json().data;",
                  "if (b) {",
                  "  pm.collectionVariables.set('bookingId', b.id);",
                  "  if (b.session_id) pm.collectionVariables.set('sessionId', b.session_id);",
                  "  console.log('Booking', b.id, 'Session', b.session_id, 'Meet', b.meet_link);",
                  "}"
                ]
              }
            }
          ]
        },
        {
          "name": "List my bookings",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/bookings/",
              "host": ["{{baseUrl}}"],
              "path": ["bookings", ""]
            },
            "description": "Returns bookings where current user is student OR teacher (auto-detected by role)."
          }
        },
        {
          "name": "Booking detail",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/bookings/{{bookingId}}/",
              "host": ["{{baseUrl}}"],
              "path": ["bookings", "{{bookingId}}", ""]
            }
          }
        },
        {
          "name": "Cancel booking",
          "request": {
            "method": "PATCH",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": {
              "raw": "{{baseUrl}}/bookings/{{bookingId}}/cancel/",
              "host": ["{{baseUrl}}"],
              "path": ["bookings", "{{bookingId}}", "cancel", ""]
            },
            "body": { "mode": "raw", "raw": "{}" }
          }
        }
      ]
    },
    {
      "name": "Sessions",
      "item": [
        {
          "name": "List my sessions",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/sessions/",
              "host": ["{{baseUrl}}"],
              "path": ["sessions", ""]
            }
          }
        },
        {
          "name": "Session detail (classroom page uses this)",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/sessions/{{sessionId}}/",
              "host": ["{{baseUrl}}"],
              "path": ["sessions", "{{sessionId}}", ""]
            }
          }
        },
        {
          "name": "Start session",
          "request": {
            "method": "PATCH",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": {
              "raw": "{{baseUrl}}/sessions/{{sessionId}}/start/",
              "host": ["{{baseUrl}}"],
              "path": ["sessions", "{{sessionId}}", "start", ""]
            },
            "body": { "mode": "raw", "raw": "{}" },
            "description": "Sets started_at and is_active=true."
          }
        },
        {
          "name": "End session (also marks booking completed)",
          "request": {
            "method": "PATCH",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": {
              "raw": "{{baseUrl}}/sessions/{{sessionId}}/end/",
              "host": ["{{baseUrl}}"],
              "path": ["sessions", "{{sessionId}}", "end", ""]
            },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"student_notes\": \"Reviewed surah Al-Fatiha makhraj. Homework: practice madd letters daily.\"\n}"
            },
            "description": "Run this BEFORE creating a review — it flips the booking status to 'completed' which is required."
          }
        }
      ]
    },
    {
      "name": "Reviews",
      "item": [
        {
          "name": "List reviews (public)",
          "request": {
            "auth": { "type": "noauth" },
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/reviews/?teacher={{teacherId}}",
              "host": ["{{baseUrl}}"],
              "path": ["reviews", ""],
              "query": [
                { "key": "teacher", "value": "{{teacherId}}", "description": "Optional — filter by teacher_profile_id" }
              ]
            }
          }
        },
        {
          "name": "Create review (auth=student, booking must be completed)",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": {
              "raw": "{{baseUrl}}/reviews/",
              "host": ["{{baseUrl}}"],
              "path": ["reviews", ""]
            },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"booking_id\": {{bookingId}},\n  \"rating\": 5,\n  \"comment\": \"Excellent teacher. Very patient and explains Tajweed rules clearly.\"\n}"
            },
            "description": "rating: 1-5. Common errors:\n- 400 'Booking not completed' → End the session first\n- 403 → you're not the student on this booking\n- 400 'Already reviewed' → review exists"
          }
        }
      ]
    }
  ]
}
